{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Glitni/dlt-saga/schemas/dlt_common.json",
  "title": "DLT Common Configuration Definitions",
  "description": "Shared definitions for dlt pipeline configurations",

  "$defs": {
    "tag_item": {
      "defaultSnippets": [
        {"label": "daily", "body": "daily"},
        {"label": "hourly", "body": "hourly"},
        {"label": "critical", "body": "critical"},
        {"label": "weekly", "body": "weekly"},
        {"label": "monthly", "body": "monthly"},
        {"label": "daily: [monday]", "body": {"daily": ["monday"]}},
        {"label": "daily: [monday, wednesday, friday]", "body": {"daily": ["monday", "wednesday", "friday"]}},
        {"label": "hourly: [1]", "body": {"hourly": [1]}},
        {"label": "hourly: [1, 10, 14]", "body": {"hourly": [1, 10, 14]}},
        {"label": "hourly: [monday]", "body": {"hourly": ["monday"]}},
        {"label": "hourly: per-weekday hours", "body": {"hourly": [{"monday": [6]}, {"tuesday": [6]}, 9]}}
      ],
      "oneOf": [
        {
          "type": "string",
          "description": "Simple tag (e.g., daily, hourly, critical)"
        },
        {
          "type": "object",
          "description": "Tag with schedule values. Examples: {daily: [monday]}, {hourly: [1, 10]}, {hourly: [{monday: [6]}, 9]} for per-weekday hourly bindings",
          "minProperties": 1,
          "maxProperties": 1,
          "additionalProperties": {
            "type": "array",
            "items": {
              "oneOf": [
                { "type": "string" },
                { "type": "integer" },
                {
                  "type": "object",
                  "description": "Per-weekday value binding (hourly only): {weekday: hour} or {weekday: [hours]}",
                  "minProperties": 1,
                  "maxProperties": 1,
                  "additionalProperties": {
                    "oneOf": [
                      { "type": "integer" },
                      {
                        "type": "array",
                        "items": { "type": "integer" }
                      }
                    ]
                  }
                }
              ]
            }
          }
        }
      ]
    },

    "tags": {
      "oneOf": [
        {
          "type": "string",
          "description": "Single tag as a string"
        },
        {
          "type": "array",
          "description": "List of tags",
          "items": {
            "$ref": "#/$defs/tag_item"
          }
        }
      ]
    },

    "string_or_array_of_strings": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ]
    },

    "schema_access_list": {
      "type": "array",
      "description": "List of schema-level access entries. On BigQuery: ROLE:entity_type:email, AUTHORIZED_DATASET:project.dataset, or AUTHORIZED_VIEW:project.dataset.view.",
      "items": {
        "type": "string",
        "pattern": "^((OWNER|WRITER|READER):(serviceAccount|user|group):.+@.+\\..+|(AUTHORIZED_DATASET|AUTHORIZED_VIEW):.+\\..+)$"
      }
    },

    "column_hint": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Column name"
        },
        "data_type": {
          "type": "string",
          "enum": ["text", "bigint", "double", "bool", "timestamp", "date", "time", "decimal", "binary", "complex", "wei"],
          "description": "Data type (text, bigint, double, bool, timestamp, date, time, decimal, binary, complex, wei)"
        },
        "nullable": {
          "type": "boolean",
          "description": "Whether column can be null"
        },
        "unique": {
          "type": "boolean",
          "description": "Whether column values must be unique"
        },
        "primary_key": {
          "type": "boolean",
          "description": "Whether column is part of primary key"
        },
        "precision": {
          "type": "integer",
          "description": "Precision for decimal types"
        },
        "scale": {
          "type": "integer",
          "description": "Scale for decimal types"
        },
        "default": {
          "description": "Default value to use when column is NULL or empty (for handling SCD2 merge key nulls)",
          "oneOf": [
            {"type": "string"},
            {"type": "number"},
            {"type": "boolean"},
            {"type": "null"}
          ]
        },
        "description": {
          "type": "string",
          "description": "Human-readable column description written to the destination column. Honored when persist_docs.columns is true."
        },
        "classification": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[A-Za-z0-9_.:-]+$"},
          "description": "Lightweight data-classification labels for the column (e.g. ['pii']). Encoded into the column description as a [saga:classification=...] block. Honored when persist_docs.columns is true. Data governance, distinct from the top-level 'tags' used for pipeline selection."
        }
      }
    }
  }
}
